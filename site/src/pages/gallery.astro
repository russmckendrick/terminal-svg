---
import Base from '../layouts/Base.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import ThemeChip from '../components/ThemeChip.astro';
import { items, themes, fixtures, THEME_META, FIXTURE_META } from '../lib/gallery';

const themeMeta = THEME_META.filter((t) => themes.includes(t.key));
const fixtureMeta = FIXTURE_META.filter((f) => fixtures.includes(f.key));
---

<Base
  title="Gallery — terminal-svg"
  description="Explore terminal-svg output across every built-in theme, fixture, and platform-native window chrome."
>
  <div class="gallery-page">
    <section class="gallery-hero">
      <div class="gallery-wrap gallery-hero-grid">
        <div data-reveal>
          <p class="gallery-kicker"><span class="signal"></span> gallery / svg output</p>
          <h1>Every terminal state, <em>rendered.</em></h1>
          <p class="gallery-lead">
            Real output from the test suite — vectors, not mockups. Pick a theme, find a fixture,
            and zoom in until the columns give themselves away.
          </p>
        </div>
        <div class="gallery-stats" data-reveal aria-label="Gallery totals">
          <div><strong>{items.length}</strong><span>SVG outputs</span></div>
          <div><strong>{themes.length}</strong><span>built-in themes</span></div>
          <div><strong>{fixtures.length}</strong><span>terminal fixtures</span></div>
        </div>
      </div>
    </section>

    <section class="gallery-catalog">
      <div class="gallery-wrap">
        <div class="gallery-toolbar" data-reveal>
          <div class="toolbar-title">
            <span class="gallery-kicker gallery-kicker--dark">Browse the output</span>
            <p data-count aria-live="polite">Showing all {items.length}</p>
          </div>
          <div class="filter-controls">
            <div class="theme-filter" data-filter-group="theme" role="group" aria-label="Filter by theme">
              <span class="filter-label">THEME</span>
              <div class="swatch-filter">
                <button class="swatch all on" type="button" data-value="" aria-label="All themes" aria-pressed="true" title="All themes">
                  <ThemeChip all />
                </button>
                {
                  themeMeta.map((t) => (
                    <button class="swatch" type="button" data-value={t.key} aria-label={t.label} aria-pressed="false" title={t.label}>
                      <ThemeChip theme={t} />
                    </button>
                  ))
                }
              </div>
              <p class="theme-name" data-theme-name>All themes</p>
            </div>
            <label class="fixture-filter">
              <span class="filter-label">FIXTURE</span>
              <select data-filter-select="fixture" aria-label="Filter by fixture">
                <option value="">All fixtures</option>
                {fixtureMeta.map((f) => <option value={f.key}>{f.label}</option>)}
              </select>
            </label>
          </div>
        </div>
      </div>

      <div class="gallery-wide">
        <GalleryGrid items={items} lightbox={true} />
        <p class="empty" data-empty hidden>Nothing matches that combination.</p>
      </div>
    </section>
  </div>

  <div class="lightbox" data-lightbox-root role="dialog" aria-modal="true" aria-labelledby="lb-caption" hidden>
    <button class="lb-close" type="button" data-lb-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="m6 6 12 12M18 6 6 18"></path>
      </svg>
    </button>
    <button class="lb-arrow lb-prev" type="button" data-lb-prev aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 5l-7 7 7 7"></path>
      </svg>
    </button>
    <figure>
      <img data-lb-img src="" alt="" />
      <figcaption id="lb-caption" data-lb-caption></figcaption>
    </figure>
    <button class="lb-arrow lb-next" type="button" data-lb-next aria-label="Next">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 5 7 7-7 7"></path>
      </svg>
    </button>
  </div>
</Base>

<style>
  .gallery-page {
    --gallery-ink: var(--home-ink);
    --gallery-paper: var(--home-paper);
    --gallery-muted: var(--home-muted);
    --gallery-accent: var(--home-accent);
    background: var(--gallery-paper);
  }

  .gallery-wrap {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .gallery-hero {
    padding: clamp(74px, 9vw, 124px) 0 clamp(66px, 8vw, 110px);
    color: var(--gallery-paper);
    background:
      radial-gradient(circle at 80% 20%, rgba(240, 162, 87, 0.1), transparent 28rem),
      var(--gallery-ink);
  }

  .gallery-hero-grid {
    display: block;
  }

  .gallery-kicker,
  .filter-label,
  .gallery-stats span {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .gallery-kicker {
    color: var(--gallery-muted);
  }

  .gallery-kicker--dark,
  .filter-label {
    color: var(--home-rust-dark);
  }

  .gallery-kicker .signal {
    display: inline-block;
    width: 7px;
    height: 7px;
    margin-right: 7px;
    border-radius: 50%;
    background: var(--gallery-accent);
    vertical-align: 1px;
  }

  .gallery-hero h1 {
    margin-top: 26px;
    font-family: var(--mono);
    font-size: clamp(50px, 7.4vw, 96px);
    font-weight: 650;
    letter-spacing: -0.08em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .gallery-hero h1 em {
    color: var(--gallery-accent);
    font-style: normal;
  }

  .gallery-lead {
    max-width: 64ch;
    margin-top: 26px;
    color: var(--gallery-muted);
    font-size: clamp(17px, 1.7vw, 21px);
    line-height: 1.55;
  }

  .gallery-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255, 194, 125, 0.28);
    border-bottom: 1px solid rgba(255, 194, 125, 0.28);
    margin-top: clamp(56px, 7vw, 92px);
  }

  .gallery-stats div {
    min-width: 0;
    padding: 20px 16px 19px 0;
  }

  .gallery-stats div + div {
    padding-left: 16px;
    border-left: 1px solid rgba(255, 194, 125, 0.2);
  }

  .gallery-stats strong {
    display: block;
    color: var(--gallery-paper);
    font-family: var(--mono);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 500;
    letter-spacing: -0.08em;
  }

  .gallery-stats span {
    display: block;
    margin-top: 8px;
    color: var(--gallery-muted);
    font-size: 9px;
    line-height: 1.4;
  }

  .gallery-catalog {
    padding: 0 0 120px;
    background: var(--gallery-paper);
  }

  .gallery-toolbar {
    position: sticky;
    top: var(--nav-h);
    z-index: 20;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 32px;
    padding: 26px 0 22px;
    background: color-mix(in srgb, var(--gallery-paper) 94%, transparent);
    border-bottom: 1px solid #d8cec0;
    backdrop-filter: blur(16px);
  }

  .toolbar-title p {
    margin-top: 12px;
    color: var(--text-dark);
    font-family: var(--mono);
    font-size: 12px;
  }

  .filter-controls {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 190px;
    gap: 40px;
    align-items: end;
  }

  .filter-label {
    display: block;
    margin-bottom: 14px;
  }

  .swatch-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 11px;
  }

  .swatch {
    padding: 0;
    border: 0;
    border-radius: 7px;
    background: none;
    cursor: pointer;
    line-height: 0;
    transition: transform 0.2s ease;
  }

  .swatch :global(svg) {
    display: block;
    width: 40px;
    height: auto;
  }

  .swatch:hover {
    transform: translateY(-2px) scale(1.08);
  }

  .swatch.on {
    outline: 2px solid var(--gallery-accent);
    outline-offset: 3px;
  }

  .theme-name {
    min-height: 1.2em;
    margin-top: 13px;
    color: var(--text-dark-2);
    font-family: var(--mono);
    font-size: 12px;
  }

  .fixture-filter select {
    width: 100%;
    padding: 8px 24px 10px 0;
    border: 0;
    border-bottom: 1px solid #bdb1a3;
    border-radius: 0;
    background: var(--gallery-paper);
    color: var(--text-dark);
    font-family: var(--mono);
    font-size: 12px;
    cursor: pointer;
  }

  .gallery-wide {
    width: min(1280px, calc(100% - 48px));
    margin: 48px auto 0;
  }

  .empty {
    padding: 80px 0;
    color: var(--text-dark-2);
    text-align: center;
    font-family: var(--mono);
    font-size: 13px;
  }

  /* lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(11, 15, 12, 0.92);
    backdrop-filter: blur(22px) saturate(120%);
    -webkit-backdrop-filter: blur(22px) saturate(120%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .lightbox.open {
    opacity: 1;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox figure {
    width: min(920px, calc(100vw - 140px));
    text-align: center;
    transform: scale(0.96);
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .lightbox.open figure {
    transform: none;
  }

  .lightbox img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 40px 80px rgba(0, 0, 0, 0.5));
  }

  .lightbox figcaption {
    margin-top: 24px;
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--mono);
    font-size: 13px;
  }

  .lb-close,
  .lb-arrow {
    position: fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 194, 125, 0.35);
    border-radius: 4px;
    background: rgba(255, 194, 125, 0.1);
    color: var(--gallery-accent);
    cursor: pointer;
  }

  .lb-close:hover,
  .lb-arrow:hover {
    background: rgba(255, 194, 125, 0.22);
  }

  .lb-close { top: 22px; right: 22px; }
  .lb-close svg,
  .lb-arrow svg { width: 18px; height: 18px; }
  .lb-prev { left: 22px; top: 50%; transform: translateY(-50%); }
  .lb-next { right: 22px; top: 50%; transform: translateY(-50%); }

  @media (max-width: 900px) {
    .gallery-toolbar,
    .filter-controls { grid-template-columns: 1fr; }
    .gallery-toolbar { gap: 24px; }
  }

  @media (max-width: 640px) {
    .gallery-wrap,
    .gallery-wide { width: min(100% - 32px, 1280px); }
    .gallery-hero-grid { display: block; }
    .gallery-hero h1 { font-size: clamp(46px, 13vw, 70px); }
    .gallery-stats strong { font-size: 30px; }
    .gallery-catalog { padding-bottom: 72px; }
    .gallery-toolbar { top: var(--nav-h); padding-top: 20px; }
    .gallery-wide { margin-top: 28px; }
    .lb-prev, .lb-next { top: auto; bottom: 22px; transform: none; }
    .lb-prev { left: calc(50% - 52px); }
    .lb-next { right: calc(50% - 52px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox,
    .lightbox figure,
    .swatch { transition: none; }
  }
</style>

<script>
  const state: Record<string, string> = { theme: '', fixture: '' };
  const tiles = document.querySelectorAll<HTMLElement>('.tile[data-theme][data-fixture]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');
  const count = document.querySelector<HTMLElement>('[data-count]');
  const themeName = document.querySelector<HTMLElement>('[data-theme-name]');
  const total = tiles.length;

  function apply() {
    let visible = 0;
    for (const tile of tiles) {
      const show =
        (!state.theme || tile.dataset.theme === state.theme) &&
        (!state.fixture || tile.dataset.fixture === state.fixture);
      tile.hidden = !show;
      if (show) visible++;
    }
    if (empty) empty.hidden = visible > 0;
    if (count) count.textContent = visible === total ? `Showing all ${total}` : `Showing ${visible} of ${total}`;
    const params = new URLSearchParams();
    if (state.theme) params.set('theme', state.theme);
    if (state.fixture) params.set('fixture', state.fixture);
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  function activate(group: HTMLElement, btn: HTMLElement) {
    const key = group.dataset.filterGroup!;
    state[key] = btn.dataset.value ?? '';
    for (const b of group.querySelectorAll('button')) {
      const selected = b === btn;
      b.classList.toggle('on', selected);
      b.setAttribute('aria-pressed', String(selected));
    }
    if (key === 'theme' && themeName) {
      themeName.textContent = btn.getAttribute('aria-label') ?? btn.textContent ?? 'All themes';
    }
  }

  for (const group of document.querySelectorAll<HTMLElement>('[data-filter-group]')) {
    group.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('button');
      if (!btn) return;
      activate(group, btn);
      apply();
    });
  }

  for (const select of document.querySelectorAll<HTMLSelectElement>('[data-filter-select]')) {
    select.addEventListener('change', () => {
      state[select.dataset.filterSelect!] = select.value;
      apply();
    });
  }

  const params = new URLSearchParams(location.search);
  for (const key of ['theme', 'fixture'] as const) {
    const value = params.get(key);
    if (!value) continue;
    const select = document.querySelector<HTMLSelectElement>(`[data-filter-select="${key}"]`);
    if (select) {
      select.value = value;
      state[key] = value;
      continue;
    }
    const btn = document.querySelector<HTMLElement>(
      `[data-filter-group="${key}"] button[data-value="${CSS.escape(value)}"]`
    );
    if (btn) activate(btn.closest<HTMLElement>('[data-filter-group]')!, btn);
  }
  apply();

  const root = document.querySelector<HTMLElement>('[data-lightbox-root]')!;
  const lbImg = root.querySelector<HTMLImageElement>('[data-lb-img]')!;
  const lbCaption = root.querySelector<HTMLElement>('[data-lb-caption]')!;
  let current = -1;
  let lastFocused: HTMLElement | null = null;

  function visibleTriggers() {
    return [...document.querySelectorAll<HTMLElement>('.tile:not([hidden]) [data-lightbox]')];
  }

  function show(index: number) {
    const triggers = visibleTriggers();
    if (!triggers.length) return;
    current = (index + triggers.length) % triggers.length;
    const trigger = triggers[current];
    lbImg.src = trigger.dataset.url ?? '';
    lbImg.alt = trigger.getAttribute('aria-label') ?? '';
    lbCaption.textContent = trigger.dataset.caption ?? '';
    const tileImg = trigger.querySelector('img');
    const ratio = tileImg ? tileImg.naturalWidth / tileImg.naturalHeight : 2;
    const figure = lbImg.closest('figure') as HTMLElement;
    const maxByHeight = (window.innerHeight - 220) * ratio;
    figure.style.width = `min(920px, calc(100vw - 140px), ${Math.round(maxByHeight)}px)`;
  }

  function open(index: number) {
    lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    show(index);
    root.hidden = false;
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      root.classList.add('open');
      root.querySelector<HTMLElement>('[data-lb-close]')?.focus();
    });
  }

  function close() {
    root.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => {
      root.hidden = true;
      lbImg.src = '';
      lastFocused?.focus();
      lastFocused = null;
    }, 300);
  }

  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest<HTMLElement>('[data-lightbox]');
    if (trigger) {
      open(visibleTriggers().indexOf(trigger));
      return;
    }
    if (!root.hidden) {
      const element = e.target as HTMLElement;
      if (element.closest('[data-lb-prev]')) return show(current - 1);
      if (element.closest('[data-lb-next]')) return show(current + 1);
      if (element.closest('[data-lb-close]') || !element.closest('figure')) close();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (root.hidden) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      show(current - 1);
    }
    if (e.key === 'ArrowRight') {
      e.preventDefault();
      show(current + 1);
    }
    if (e.key === 'Tab') {
      const focusable = [...root.querySelectorAll<HTMLElement>('button')];
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (!first || !last) return;
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>

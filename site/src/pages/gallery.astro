---
import Base from '../layouts/Base.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { items, themes, fixtures } from '../lib/gallery';
---

<Base
  title="Gallery — terminal-svg"
  description="Every terminal-svg test fixture rendered in all seven built-in themes: Dracula, Catppuccin Mocha, Nord, Tokyo Night, GitHub dark & light, and Solarized."
>
  <section class="section section--gray">
    <div class="wrap">
      <h1 class="headline" data-reveal>Every theme.<br />Every fixture.</h1>
      <p class="subhead narrow" data-reveal>
        {fixtures.length} test fixtures × {themes.length} themes — {items.length} SVGs,
        rendered straight from the repo. Zoom right in — they're vectors.
      </p>

      <div class="filters" data-reveal>
        <div class="seg" data-filter-group="theme" role="group" aria-label="Filter by theme">
          <button class="on" data-value="">All themes</button>
          {themes.map((t) => <button data-value={t}>{t}</button>)}
        </div>
        <div class="seg" data-filter-group="fixture" role="group" aria-label="Filter by fixture">
          <button class="on" data-value="">All fixtures</button>
          {fixtures.map((f) => <button data-value={f}>{f}</button>)}
        </div>
      </div>

      <GalleryGrid items={items} />

      <p class="empty" data-empty hidden>Nothing matches that combination.</p>
    </div>
  </section>
</Base>

<style>
  .filters {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin: 48px 0 56px;
  }

  .seg {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
    background: #e8e8ed;
    border-radius: 980px;
    padding: 4px;
  }

  .seg button {
    font-family: var(--sans);
    font-size: 13px;
    letter-spacing: -0.01em;
    color: var(--text-dark);
    background: none;
    border: none;
    border-radius: 980px;
    padding: 6px 14px;
    cursor: pointer;
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }

  .seg button:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  .seg button.on {
    background: var(--white);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
    font-weight: 600;
  }

  .empty {
    text-align: center;
    color: var(--text-dark-2);
    margin-top: 48px;
  }

  @media (max-width: 640px) {
    .seg {
      border-radius: 22px;
    }
  }
</style>

<script>
  const state: Record<string, string> = { theme: '', fixture: '' };
  const cards = document.querySelectorAll<HTMLElement>('[data-theme][data-fixture]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const show =
        (!state.theme || card.dataset.theme === state.theme) &&
        (!state.fixture || card.dataset.fixture === state.fixture);
      card.hidden = !show;
      if (show) visible++;
    }
    if (empty) empty.hidden = visible > 0;
    const params = new URLSearchParams();
    if (state.theme) params.set('theme', state.theme);
    if (state.fixture) params.set('fixture', state.fixture);
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  for (const group of document.querySelectorAll<HTMLElement>('[data-filter-group]')) {
    const key = group.dataset.filterGroup!;
    group.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button');
      if (!btn) return;
      state[key] = btn.dataset.value ?? '';
      for (const b of group.querySelectorAll('button')) b.classList.toggle('on', b === btn);
      apply();
    });
  }

  // deep links: /gallery/?theme=nord&fixture=starship
  const params = new URLSearchParams(location.search);
  for (const key of ['theme', 'fixture'] as const) {
    const value = params.get(key);
    if (!value) continue;
    const btn = document.querySelector<HTMLElement>(
      `[data-filter-group="${key}"] button[data-value="${CSS.escape(value)}"]`
    );
    if (btn) {
      state[key] = value;
      const group = btn.closest('[data-filter-group]')!;
      for (const b of group.querySelectorAll('button')) b.classList.toggle('on', b === btn);
    }
  }
  apply();
</script>

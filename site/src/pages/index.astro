---
import Base from "../layouts/Base.astro";
import CodeSnippet from "../components/CodeSnippet.astro";
import { find, themeLabel } from "../lib/gallery";
import { getLatest, REPO_URL, formatDate, formatSize } from "../lib/releases";
import demoUrl from "../../../docs/assets/demo.svg?url";

const latest = await getLatest();
const version = latest?.tag.replace(/^v/, "") ?? "0.6.0";
const progress = find("github-light", "progress");
const styles = find("github-light", "sgr-styles");

const themeSpecimens = ["dracula", "github-light", "nord", "ubuntu"].flatMap(
  (theme) => {
    const item = find(theme, "starship");
    return item ? [{ ...item, label: themeLabel(theme) }] : [];
  },
);

const inputModes = [
  {
    number: "01",
    title: "Run a command",
    copy: "Capture under a real PTY, so colour and interactive output stay switched on.",
    command: "terminal-svg -o help.svg -- terminal-svg --help",
  },
  {
    number: "02",
    title: "Pipe ANSI",
    copy: "Turn an existing coloured stream into a finished document.",
    command: "ls --color=always | terminal-svg",
  },
  {
    number: "03",
    title: "Render a capture",
    copy: "Resolve cursor movement, clears, progress bars, and terminal state.",
    command: "terminal-svg dump.ansi",
  },
  {
    number: "04",
    title: "Replay a recording",
    copy: "Render asciicast v2 or v3 as compact, pure-SVG animation.",
    command: "terminal-svg demo.cast",
  },
  {
    number: "05",
    title: "Rework an SVG",
    copy: "Re-theme or resize a terminal-svg file without making the capture again.",
    command: "terminal-svg demo.svg -t nord",
  },
];

const PLATFORMS: [RegExp, string][] = [
  [/darwin-arm64/, "macOS · Apple silicon"],
  [/darwin-amd64/, "macOS · Intel"],
  [/linux-arm64/, "Linux · arm64"],
  [/linux-amd64/, "Linux · x86_64"],
  [/windows-amd64/, "Windows · x86_64"],
];

const binaries = (latest?.assets ?? [])
  .filter((asset) => !/\.sha256$|\.txt$/i.test(asset.name))
  .map((asset) => {
    const platform = PLATFORMS.find(([pattern]) =>
      pattern.test(asset.name),
    )?.[1];
    return platform ? { ...asset, platform } : null;
  })
  .filter((asset) => asset !== null);
---

<Base
  title="terminal-svg — Terminal output, ready to publish"
  description="Capture commands, ANSI streams, and asciicasts as faithful, self-contained SVG documents."
>
  <div class="home">
    <section class="hero">
      <div class="shell hero-layout">
        <div class="hero-copy">
          <p class="hero-kicker">Terminal capture · native SVG</p>
          <h1>
            Terminal output,
            <span>ready to publish.</span>
          </h1>
          <p class="hero-lead">
            Capture a command, ANSI stream, or recording as a faithful SVG.
            Fonts, colour, animation, and source data travel in one file.
          </p>
          <div class="hero-actions">
            <a class="button button--primary" href="/docs/install/"
              >Install terminal-svg</a
            >
            <a class="button button--secondary" href="/gallery/"
              >See real output</a
            >
          </div>
          <div class="hero-command">
            <span>Try it</span>
            <code>terminal-svg -o help.svg -- terminal-svg --help</code>
            <button
              type="button"
              data-copy="terminal-svg -o help.svg -- terminal-svg --help"
              aria-label="Copy terminal-svg example command">Copy</button
            >
          </div>
        </div>

        <figure class="hero-artifact">
          <img
            class="hero-output"
            src={demoUrl}
            alt="Animated deployment command captured by terminal-svg"
            width="555.2"
            height="321"
            loading="eager"
            fetchpriority="high"
          />
          <figcaption>
            <div>
              <strong>demo.svg</strong>
              <span>Generated by terminal-svg</span>
            </div>
            <dl>
              <div><dt>Canvas</dt><dd>555 × 321</dd></div>
              <div><dt>Playback</dt><dd>Pure SVG</dd></div>
              <div><dt>Font</dt><dd>Embedded</dd></div>
            </dl>
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="fact-strip" aria-label="Product facts">
      <div class="shell fact-grid">
        <div><strong>One binary</strong><span>Written in Rust</span></div>
        <div><strong>Five inputs</strong><span>Command to asciicast</span></div>
        <div><strong>Zero runtime</strong><span>SVG and CSS only</span></div>
        <div>
          <strong>Source included</strong><span>Extract and re-render</span>
        </div>
      </div>
    </section>

    <section class="workflow-section">
      <div class="shell workflow-layout">
        <div class="workflow-heading">
          <p class="section-label">Capture workflow</p>
          <h2>Five ways in.<br />One honest file out.</h2>
          <p>
            terminal-svg reads the same things your terminal does. Choose the
            input you already have; every route ends in a portable SVG.
          </p>
          <a class="text-link" href="/docs/usage/"
            >Read the CLI reference <span aria-hidden="true">↗</span></a
          >
        </div>

        <ol class="mode-list">
          {
            inputModes.map((mode) => (
              <li>
                <span>{mode.number}</span>
                <div>
                  <h3>{mode.title}</h3>
                  <p>{mode.copy}</p>
                  <div class="mode-command">
                    <code>{mode.command}</code>
                    <button
                      type="button"
                      data-copy={mode.command}
                      aria-label={`Copy ${mode.title} command`}
                    >
                      Copy
                    </button>
                  </div>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="roundtrip-section">
      <div class="shell roundtrip-layout">
        <div class="roundtrip-proof">
          <div class="proof-sheet">
            <span class="sheet-label">THE SVG IS THE SOURCE</span>
            {
              styles && (
                <img
                  src={styles.url}
                  alt="Text styling faithfully rendered in an SVG"
                  width={styles.width}
                  height={styles.height}
                  loading="lazy"
                />
              )
            }
            <div class="sheet-details">
              <span>ANSI capture</span>
              <span>Render options</span>
              <span>Subset font</span>
            </div>
          </div>
          {
            progress && (
              <div class="proof-inset">
                <img
                  src={progress.url}
                  alt="Progress output rendered by terminal-svg"
                  width={progress.width}
                  height={progress.height}
                  loading="lazy"
                />
              </div>
            )
          }
        </div>

        <div class="section-copy">
          <p class="section-label">Round-trip by design</p>
          <h2>Not a screenshot with a new extension.</h2>
          <p>
            Every terminal-svg file can carry its original ANSI or asciicast
            source alongside the effective render options. Re-theme it, resize
            it, or recover the recording later.
          </p>
          <div class="roundtrip-commands">
            <CodeSnippet
              label="Re-render directly"
              code="terminal-svg demo.svg -t github-dark -o dark.svg"
            />
            <CodeSnippet
              label="Recover the capture"
              code="terminal-svg extract demo.svg -o demo.cast"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="themes-section">
      <div class="shell">
        <div class="themes-heading">
          <div>
            <p class="section-label">Built-in themes</p>
            <h2>Same capture.<br />Different destination.</h2>
          </div>
          <div>
            <p>
              Nine documented palettes, custom TOML themes, and light/dark pairs
              for SVGs that follow the viewer’s colour scheme.
            </p>
            <a class="text-link" href="/docs/themes/"
              >Explore theme options <span aria-hidden="true">↗</span></a
            >
          </div>
        </div>

        <div class="theme-specimens">
          {
            themeSpecimens.map((specimen, index) => (
              <figure>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <img
                  src={specimen.url}
                  alt={
                    "Starship prompt rendered with the " +
                    specimen.label +
                    " theme"
                  }
                  width={specimen.width}
                  height={specimen.height}
                  loading="lazy"
                />
                <figcaption>{specimen.label}</figcaption>
              </figure>
            ))
          }
        </div>
        <a class="gallery-cta" href="/gallery/">
          <span>Browse every fixture and theme</span>
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>

    <section class="install-section">
      <div class="shell install-layout">
        <div class="install-copy">
          <p class="section-label">Get terminal-svg</p>
          <h2>One command.<br />Your first SVG.</h2>
          {
            latest && (
              <p>
                Latest: v{version}, released {formatDate(latest.publishedAt)}.
              </p>
            )
          }
        </div>
        <div class="install-panel">
          <CodeSnippet
            code="brew install russmckendrick/tap/terminal-svg"
            label="Homebrew"
          />
          <CodeSnippet
            code="terminal-svg -o help.svg -- terminal-svg --help"
            label="First capture"
          />
          <div class="install-links">
            <a href="/docs/install/"
              >All installation methods <span aria-hidden="true">↗</span></a
            >
            <a href={REPO_URL + "/releases/latest"} rel="noopener"
              >GitHub release <span aria-hidden="true">↗</span></a
            >
          </div>
          {
            binaries.length > 0 && (
              <details class="binary-list">
                <summary>Download a prebuilt binary</summary>
                <ul>
                  {binaries.map((binary) => (
                    <li>
                      <a href={binary.url} rel="noopener">
                        <span>{binary.platform}</span>
                        <span>{formatSize(binary.size)} ↗</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            )
          }
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .home {
    overflow: clip;
  }

  .hero {
    position: relative;
    padding: clamp(72px, 8vw, 124px) 0 clamp(78px, 9vw, 132px);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(500px, 1.18fr);
    align-items: center;
    gap: clamp(58px, 8vw, 116px);
  }

  .hero-copy {
    position: relative;
    z-index: 2;
  }

  .hero-kicker {
    color: var(--accent-deep);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 680;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 720px;
    margin-top: 24px;
    font-size: clamp(61px, 7vw, 108px);
    font-weight: 720;
    letter-spacing: -0.075em;
    line-height: 0.88;
  }

  .hero h1 span {
    display: block;
    color: var(--accent);
  }

  .hero-lead {
    max-width: 620px;
    margin-top: 32px;
    color: var(--ink-soft);
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 29px;
  }

  .hero-command {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 13px;
    max-width: 540px;
    margin-top: 37px;
    padding-top: 18px;
    border-top: 1px solid var(--line-strong);
  }

  .hero-command span,
  .hero-command button {
    color: var(--ink-faint);
    font-size: 11px;
    font-weight: 700;
  }

  .hero-command code {
    min-width: 0;
    overflow: hidden;
    color: var(--ink);
    font-family: var(--mono);
    font-size: 12px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hero-command button {
    padding: 5px;
    color: var(--accent-deep);
    background: none;
    border: 0;
    cursor: pointer;
  }

  .hero-artifact {
    min-width: 0;
    margin: 0 clamp(-72px, -4vw, -36px) 0 clamp(-28px, -1.5vw, -10px);
  }

  .hero-output {
    display: block;
    width: 112%;
    max-width: none;
    height: auto;
  }

  .hero-artifact figcaption {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 28px;
    width: 94%;
    margin-top: -3px;
    margin-left: 3%;
    padding-top: 16px;
    border-top: 1px solid var(--line-strong);
  }

  .hero-artifact figcaption strong,
  .hero-artifact figcaption > div > span {
    display: block;
  }

  .hero-artifact figcaption strong {
    font-size: 14px;
  }

  .hero-artifact figcaption > div > span {
    margin-top: 2px;
    color: var(--ink-faint);
    font-size: 12px;
  }

  .hero-artifact dl {
    display: flex;
    gap: 28px;
    margin: 0;
  }

  .hero-artifact dl div {
    display: grid;
    gap: 2px;
  }

  .hero-artifact dt {
    color: var(--ink-faint);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero-artifact dd {
    margin: 0;
    font-family: var(--mono);
    font-size: 11px;
  }

  .fact-strip {
    color: var(--surface);
    background: var(--ink);
  }

  .fact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .fact-grid div {
    padding: 30px 26px 32px;
    border-left: 1px solid #343432;
  }

  .fact-grid div:last-child {
    border-right: 1px solid #343432;
  }

  .fact-grid strong,
  .fact-grid span {
    display: block;
  }

  .fact-grid strong {
    font-size: 15px;
  }

  .fact-grid span {
    margin-top: 4px;
    color: #a8a7a1;
    font-size: 12px;
  }

  .workflow-section,
  .roundtrip-section,
  .themes-section,
  .install-section {
    padding: clamp(100px, 11vw, 170px) 0;
  }

  .workflow-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(540px, 1.28fr);
    align-items: start;
    gap: clamp(70px, 10vw, 150px);
  }

  .workflow-heading {
    position: sticky;
    top: calc(var(--nav-h) + 58px);
  }

  .workflow-heading h2,
  .section-copy h2,
  .themes-heading h2,
  .install-copy h2 {
    margin-top: 22px;
    font-size: clamp(48px, 5.6vw, 78px);
    font-weight: 700;
    letter-spacing: -0.065em;
    line-height: 0.96;
  }

  .workflow-heading > p:not(.section-label),
  .section-copy > p:not(.section-label),
  .themes-heading > div:last-child p,
  .install-copy > p:not(.section-label) {
    margin-top: 26px;
    color: var(--ink-soft);
    font-size: 18px;
    line-height: 1.58;
  }

  .workflow-heading .text-link,
  .themes-heading .text-link {
    margin-top: 28px;
  }

  .mode-list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--line-strong);
  }

  .mode-list li {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr);
    gap: 24px;
    padding: 31px 0 34px;
    border-bottom: 1px solid var(--line-strong);
  }

  .mode-list li > div {
    min-width: 0;
  }

  .mode-list li > span {
    padding-top: 4px;
    color: var(--accent);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
  }

  .mode-list h3 {
    font-size: 23px;
    letter-spacing: -0.035em;
  }

  .mode-list p {
    max-width: 600px;
    margin-top: 7px;
    color: var(--ink-soft);
    font-size: 15px;
  }

  .mode-command {
    display: flex;
    width: min(100%, 520px);
    align-items: center;
    margin-top: 13px;
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .mode-command code {
    flex: 1 1 auto;
    min-width: 0;
    padding: 6px 9px;
    overflow: hidden;
    color: var(--ink);
    font-family: var(--mono);
    font-size: 11px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .mode-command button {
    flex: 0 0 auto;
    align-self: stretch;
    padding: 5px 9px;
    color: var(--accent-deep);
    background: transparent;
    border: 0;
    border-left: 1px solid var(--line);
    font-size: 10px;
    font-weight: 700;
    cursor: pointer;
  }

  .mode-command button:hover,
  .mode-command button.copied {
    color: white;
    background: var(--accent-deep);
  }

  .roundtrip-section {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .roundtrip-layout {
    display: grid;
    grid-template-columns: minmax(540px, 1.18fr) minmax(0, 0.82fr);
    align-items: center;
    gap: clamp(70px, 9vw, 130px);
  }

  .roundtrip-proof {
    position: relative;
    min-height: 590px;
  }

  .proof-sheet {
    position: absolute;
    inset: 0 74px 54px 0;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 32px;
    padding: 28px;
    background: #dedbd2;
    border: 1px solid #cbc5b9;
  }

  .sheet-label {
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .proof-sheet img {
    display: block;
    width: 100%;
    align-self: center;
  }

  .sheet-details {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sheet-details span {
    padding: 5px 8px;
    color: var(--ink-soft);
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(23, 23, 21, 0.12);
    font-size: 10px;
    font-weight: 680;
  }

  .proof-inset {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 55%;
    padding: 21px;
    background: var(--surface);
    border: 1px solid var(--ink);
    box-shadow: 14px 14px 0 var(--accent);
  }

  .proof-inset img {
    display: block;
    width: 100%;
  }

  .section-copy {
    max-width: 560px;
  }

  .roundtrip-commands {
    display: grid;
    gap: 12px;
    margin-top: 35px;
  }

  .roundtrip-commands :global(.snippet) {
    border-radius: 0;
    box-shadow: none;
  }

  .themes-section {
    background: #e8e3d8;
  }

  .themes-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    align-items: end;
    gap: 90px;
  }

  .themes-heading > div:last-child {
    padding-bottom: 5px;
  }

  .theme-specimens {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    margin-top: 76px;
    background: #c7c1b6;
    border: 1px solid #c7c1b6;
  }

  .theme-specimens figure {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 18px;
    margin: 0;
    padding: 24px;
    background: var(--canvas);
  }

  .theme-specimens figure > span {
    color: var(--accent);
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
  }

  .theme-specimens img {
    display: block;
    width: 100%;
    align-self: center;
  }

  .theme-specimens figcaption {
    grid-column: 2;
    color: var(--ink-soft);
    font-size: 12px;
    font-weight: 700;
  }

  .gallery-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 25px 3px 0;
    color: var(--ink);
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
  }

  .gallery-cta:hover {
    color: var(--accent-deep);
  }

  .install-section {
    color: white;
    background: var(--ink);
  }

  .install-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    align-items: start;
    gap: clamp(60px, 9vw, 120px);
  }

  .install-copy .section-label {
    color: #ff9c87;
  }

  .install-copy .section-label::before {
    background: #ff9c87;
  }

  .install-copy h2 {
    color: white;
  }

  .install-copy > p:not(.section-label) {
    color: #aaa9a3;
    font-size: 16px;
  }

  .install-panel {
    display: grid;
    gap: 16px;
  }

  .install-panel :global(.snippet) {
    border-radius: 0;
    box-shadow: none;
  }

  .install-links {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    padding-top: 7px;
  }

  .install-links a,
  .binary-list a {
    color: #ff9c87;
    font-size: 14px;
    font-weight: 680;
    text-decoration: none;
  }

  .binary-list {
    margin-top: 8px;
    border-top: 1px solid #343432;
  }

  .binary-list summary {
    padding: 18px 0;
    color: white;
    font-size: 14px;
    font-weight: 680;
    cursor: pointer;
  }

  .binary-list ul {
    list-style: none;
    padding: 0 0 8px;
  }

  .binary-list li {
    border-top: 1px solid #30302e;
  }

  .binary-list a {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 0;
  }

  @media (max-width: 1050px) {
    .hero-layout,
    .workflow-layout,
    .roundtrip-layout {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: 820px;
    }

    .hero-artifact {
      max-width: 900px;
      margin: 0;
    }

    .hero-output {
      width: 100%;
      max-width: 100%;
    }

    .workflow-heading {
      position: static;
      max-width: 700px;
    }

    .mode-list {
      max-width: 820px;
    }

    .roundtrip-proof {
      max-width: 820px;
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: 58px;
    }

    .hero h1 {
      font-size: clamp(55px, 16.5vw, 78px);
      line-height: 0.91;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-command span {
      display: none;
    }

    .hero-command {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .hero-artifact figcaption,
    .themes-heading,
    .install-layout {
      grid-template-columns: 1fr;
    }


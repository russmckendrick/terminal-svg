---
import Base from '../../layouts/Base.astro';
import { DOCS } from '../../lib/docs';

const guideCount = DOCS.length;
---

<Base
  title="Docs — terminal-svg"
  description={`${guideCount} terminal-svg documentation guides sourced from docs/*.md.`}
>
  <div class="docs-page">
    <section class="docs-hero">
      <div class="docs-wrap" data-reveal>
        <p class="docs-kicker"><span class="signal"></span> {guideCount} guides / docs/*.md</p>
        <h1>Documentation.</h1>
        <p class="docs-lead">The pages below are generated from the repository documentation.</p>
      </div>
    </section>

    <section class="docs-content">
      <div class="docs-wrap">
        <div class="docs-list-head" data-reveal>
          <h2>Guides</h2>
          <span>{guideCount} pages</span>
        </div>
        <div class="docs-list" data-reveal>
          {DOCS.map((doc) => (
            <a class="docs-card" href={`/docs/${doc.slug}/`}>
              <span class="docs-card-copy">
                <span class="docs-card-label">{doc.label}</span>
                <strong>{doc.title}</strong>
                <span>{doc.deck}</span>
              </span>
              <span class="docs-card-arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .docs-page { background: var(--home-paper); }
  .docs-wrap { width: min(1180px, calc(100% - 48px)); margin: 0 auto; }
  .docs-hero {
    padding: clamp(74px, 9vw, 124px) 0 clamp(70px, 8vw, 110px);
    color: var(--home-paper);
    background: radial-gradient(circle at 76% 20%, rgba(240, 162, 87, 0.1), transparent 28rem), var(--home-ink);
  }
  .docs-hero > .docs-wrap { max-width: 1180px; }
  .docs-kicker,
  .docs-card-label { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
  .docs-kicker { color: var(--home-muted); }
  .docs-kicker--dark { color: var(--home-rust-dark); }
  .docs-kicker .signal {
    display: inline-block;
    width: 7px;
    height: 7px;
    margin-right: 7px;
    border-radius: 50%;
    background: var(--home-accent);
    vertical-align: 1px;
  }
  .docs-hero h1 {
    margin-top: 26px;
    font-family: var(--mono);
    font-size: clamp(46px, 6vw, 78px);
    font-weight: 650;
    letter-spacing: -0.08em;
    line-height: 0.98;
  }
  .docs-lead {
    margin-top: 26px;
    color: var(--home-muted);
    font-size: clamp(17px, 1.7vw, 21px);
    line-height: 1.55;
  }
  .docs-content { padding: clamp(70px, 8vw, 110px) 0 130px; }
  .docs-list-head { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; padding-bottom: 18px; border-bottom: 1px solid #d8cec0; }
  .docs-list-head h2 { color: var(--home-ink); font-family: var(--mono); font-size: clamp(34px, 4vw, 52px); letter-spacing: -0.07em; }
  .docs-list-head span { color: var(--text-dark-2); font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; }
  .docs-list { border-top: 0; }
  .docs-card { display: grid; grid-template-columns: minmax(0, 1fr) 22px; gap: 24px; align-items: start; padding: 24px 0; border-bottom: 1px solid #d8cec0; color: var(--text-dark); }
  .docs-card:hover { text-decoration: none; }
  .docs-card-copy { display: flex; flex-direction: column; min-width: 0; gap: 7px; }
  .docs-card-label { color: var(--text-dark-2); font-size: 10px; }
  .docs-card-copy strong { font-family: var(--mono); font-size: 20px; letter-spacing: -0.05em; }
  .docs-card-copy > span:last-child { color: var(--text-dark-2); font-size: 15px; line-height: 1.45; }
  .docs-card-arrow { color: var(--home-rust-dark); font-family: var(--mono); font-size: 18px; }
  @media (max-width: 800px) {
    .docs-card-copy > span:last-child { max-width: 60ch; }
  }
  @media (max-width: 560px) {
    .docs-wrap { width: min(100% - 32px, 1180px); }
    .docs-hero h1 { font-size: clamp(46px, 13vw, 70px); }
    .docs-list-head { align-items: flex-start; flex-direction: column; gap: 8px; }
  }
</style>

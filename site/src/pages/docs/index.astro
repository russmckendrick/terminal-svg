---
import Base from "../../layouts/Base.astro";
import CodeSnippet from "../../components/CodeSnippet.astro";
import DocsSearch from "../../components/DocsSearch.astro";
import { DOCS } from "../../lib/docs";
---

<Base
  title="Documentation — terminal-svg"
  description="Install terminal-svg, capture commands and recordings, customise themes, and explore the CLI reference."
>
  <div class="docs-home">
    <header class="docs-heading shell">
      <div>
        <p class="section-label">Documentation</p>
        <h1>From your first capture<br />to the final detail.</h1>
        <p>
          Task-focused guides for installing, capturing, customising, and
          understanding terminal-svg.
        </p>
      </div>
      <DocsSearch docs={DOCS} />
    </header>

    <section class="quickstart">
      <div class="shell quickstart-layout">
        <div class="quickstart-copy">
          <span>01</span>
          <h2>Draw your first SVG</h2>
          <p>
            Install with Homebrew, then put any command after <code>--</code>.
          </p>
          <a class="text-link" href="/docs/install/"
            >Full installation guide <span aria-hidden="true">↗</span></a
          >
        </div>
        <div class="quickstart-code">
          <CodeSnippet
            code="brew install russmckendrick/tap/terminal-svg"
            label="Install"
          />
          <CodeSnippet
            code="terminal-svg -o help.svg -- terminal-svg --help"
            label="Capture"
          />
        </div>
      </div>
    </section>

    <section class="guide-section shell">
      <div class="guide-heading">
        <div>
          <p class="section-label">Browse the guides</p><h2>
            Everything in one path.
          </h2>
        </div>
        <span>{DOCS.length} guides</span>
      </div>
      <div class="guide-list">
        {
          DOCS.map((doc, index) => (
            <a href={`/docs/${doc.slug}/`}>
              <span class="guide-index">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="guide-copy">
                <>
                  <strong>{doc.title}</strong>
                  <span>{doc.deck}</span>
                </>
              </span>
              <span class="guide-arrow" aria-hidden="true">
                ↗
              </span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>

<style>
  .docs-home {
    padding-bottom: 130px;
  }

  .docs-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.68fr);
    align-items: end;
    gap: clamp(50px, 8vw, 120px);
    padding-top: clamp(72px, 9vw, 124px);
    padding-bottom: 70px;
  }

  .docs-heading h1 {
    max-width: 850px;
    margin-top: 20px;
    font-size: clamp(54px, 7vw, 92px);
    font-weight: 700;
    letter-spacing: -0.065em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .docs-heading > div > p:last-child {
    max-width: 630px;
    margin-top: 24px;
    color: var(--ink-soft);
    font-size: 19px;
  }

  .quickstart {
    padding: 62px 0;
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .quickstart-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    align-items: center;
    gap: clamp(50px, 8vw, 110px);
  }

  .quickstart-copy > span,
  .guide-index {
    color: var(--blue);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
  }

  .quickstart-copy h2 {
    margin-top: 14px;
    font-size: clamp(38px, 4vw, 54px);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .quickstart-copy p {
    margin-top: 18px;
    color: var(--ink-soft);
  }

  .quickstart-copy code {
    color: var(--blue-deep);
    font-family: var(--mono);
    font-size: 0.85em;
  }

  .quickstart-copy .text-link {
    margin-top: 24px;
  }

  .quickstart-code {
    display: grid;
    gap: 14px;
  }

  .quickstart-code :global(.snippet) {
    box-shadow: none;
  }

  .guide-section {
    padding-top: 100px;
  }

  .guide-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 30px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line-strong);
  }

  .guide-heading h2 {
    margin-top: 14px;
    font-size: clamp(38px, 4.8vw, 64px);
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .guide-heading > span {
    color: var(--ink-soft);
    font-size: 13px;
    font-weight: 680;
  }

  .guide-list a {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr) auto;
    align-items: center;
    gap: 22px;
    padding: 25px 8px;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    transition:
      background-color 180ms ease,
      padding 180ms ease;
  }

  .guide-list a:hover {
    padding-inline: 18px;
    background: var(--surface);
  }

  .guide-copy strong,
  .guide-copy > span {
    display: block;
  }

  .guide-copy strong {
    font-size: 20px;
    letter-spacing: -0.025em;
  }

  .guide-copy > span {
    max-width: 70ch;
    margin-top: 5px;
    color: var(--ink-soft);
    font-size: 14px;
  }

  .guide-arrow {
    color: var(--blue);
    font-size: 20px;
  }

  @media (max-width: 820px) {
    .docs-heading,
    .quickstart-layout {
      grid-template-columns: 1fr;
    }

    .docs-heading {
      align-items: start;
    }
  }

  @media (max-width: 560px) {
    .docs-home {
      padding-bottom: 90px;
    }

    .docs-heading {
      padding-top: 54px;
      padding-bottom: 52px;
    }

    .docs-heading h1 {
      font-size: clamp(48px, 14vw, 68px);
    }

    .quickstart {
      padding-block: 48px;
    }

    .guide-section {
      padding-top: 72px;
    }

    .guide-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .guide-list a {
      grid-template-columns: 34px minmax(0, 1fr) auto;
      gap: 12px;
    }

    .guide-copy > span {
      display: none;
    }
  }
</style>

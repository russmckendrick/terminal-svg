---
import Base from '../layouts/Base.astro';
import ReleaseEntry from '../components/ReleaseEntry.astro';
import { getReleases, REPO_URL } from '../lib/releases';

const releases = await getReleases();
---

<Base
  title="Releases — terminal-svg"
  description="Release notes, binaries, and the reasoning behind each terminal-svg release."
>
  <div class="release-page">
    <section class="release-hero">
      <div class="release-wrap">
        <div data-reveal>
          <p class="release-kicker"><span class="signal"></span> changelog</p>
          <h1>Release notes.</h1>
        </div>
      </div>
    </section>

    <section class="release-list">
      <div class="release-wrap">
        <div class="release-list-head" data-reveal>
          <span class="release-kicker release-kicker--dark">Version history</span>
          <a href="/docs/install/">Install guide ↗</a>
        </div>
        {
          releases.length > 0 ? (
            <div class="timeline">
              {releases.map((release, i) => <ReleaseEntry release={release} latest={i === 0} />)}
            </div>
          ) : (
            <p class="fallback" data-reveal>
              Release data wasn't available when this page was built. See the{' '}
              <a href={`${REPO_URL}/releases`} rel="noopener">releases on GitHub ↗</a>
            </p>
          )
        }
      </div>
    </section>
  </div>
</Base>

<style>
  .release-page {
    background: var(--home-paper);
  }

  .release-wrap {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .release-hero {
    padding: clamp(74px, 9vw, 124px) 0 clamp(54px, 6vw, 82px);
    color: var(--home-paper);
    background:
      radial-gradient(circle at 75% 20%, rgba(240, 162, 87, 0.1), transparent 28rem),
      var(--home-ink);
  }

  .release-kicker,
  .release-list-head {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .release-kicker {
    color: var(--home-muted);
  }

  .release-kicker--dark,
  .release-list-head a {
    color: var(--home-rust-dark);
  }

  .release-kicker .signal {
    display: inline-block;
    width: 7px;
    height: 7px;
    margin-right: 7px;
    border-radius: 50%;
    background: var(--home-accent);
    vertical-align: 1px;
  }

  .release-hero h1 {
    margin-top: 26px;
    font-family: var(--mono);
    font-size: clamp(48px, 6.5vw, 84px);
    font-weight: 650;
    letter-spacing: -0.08em;
    line-height: 0.98;
  }

  .release-hero h1 em {
    color: var(--home-accent);
    font-style: normal;
  }

  .release-list {
    padding: 0 0 120px;
  }

  .release-list-head {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding: 25px 0 21px;
    border-bottom: 1px solid #d8cec0;
  }

  .release-list-head a {
    font-size: 11px;
  }

  .timeline {
    max-width: 920px;
    margin: 0 auto;
  }

  .fallback {
    padding: 70px 0;
    color: var(--text-dark-2);
    font-family: var(--mono);
    font-size: 13px;
    text-align: center;
  }

  @media (max-width: 560px) {
    .release-wrap { width: min(100% - 32px, 1180px); }
    .release-hero h1 { font-size: clamp(46px, 13vw, 70px); }
    .release-list { padding-bottom: 72px; }
    .release-list-head { align-items: flex-start; flex-direction: column; gap: 12px; }
  }
</style>

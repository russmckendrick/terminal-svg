---
import { REPO_URL } from '../lib/releases';

const path = Astro.url.pathname;
const links = [
  { name: 'Overview', href: '/' },
  { name: 'Gallery', href: '/gallery/' },
  { name: 'Releases', href: '/releases/' },
];

function active(href: string) {
  return href === '/' ? path === '/' : path.startsWith(href);
}
---

<nav class="nav">
  <div class="inner">
    <a class="brand" href="/">terminal‑svg</a>
    <div class="links">
      {
        links.map((l) => (
          <a href={l.href} class:list={{ on: active(l.href) }}>
            {l.name}
          </a>
        ))
      }
      <a href={REPO_URL} rel="noopener">GitHub</a>
      <a class="cta" href="/#get">Install</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(22, 22, 23, 0.8);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
  }

  .inner {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    color: #f5f5f7;
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.022em;
  }

  .brand:hover {
    text-decoration: none;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .links a {
    color: rgba(255, 255, 255, 0.8);
    font-size: 13px;
    letter-spacing: -0.01em;
  }

  .links a:hover {
    color: #fff;
    text-decoration: none;
  }

  .links a.on {
    color: #fff;
    font-weight: 600;
  }

  .cta {
    background: var(--blue);
    color: #fff !important;
    padding: 5px 14px;
    border-radius: 980px;
    font-size: 13px;
  }

  .cta:hover {
    background: var(--blue-hover);
  }

  @media (max-width: 560px) {
    .links {
      gap: 13px;
    }

    .links a {
      font-size: 12px;
    }

    /* the brand already links home — drop Overview on small screens */
    .links a:first-child {
      display: none;
    }

    .brand {
      font-size: 15px;
    }
  }
</style>

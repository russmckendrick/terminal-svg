---
// One release, git-log style: yellow tag line, dim date, indented notes,
// downloads as an ls -la listing inside a <details>.
import type { Release } from '../lib/releases';
import { formatDate, formatSize } from '../lib/releases';

interface Props {
  release: Release;
  latest?: boolean;
}

const { release, latest = false } = Astro.props;
---

<article class="entry">
  <p class="head">
    <span class="tag">tag: <a href={release.htmlUrl} rel="noopener">{release.tag}</a></span>
    {latest && <span class="latest">(HEAD)</span>}
    <span class="date">{formatDate(release.publishedAt)}</span>
  </p>
  {release.name !== release.tag && <p class="name">{release.name}</p>}
  <div class="body">
    {release.bodyHtml && <div class="prose" set:html={release.bodyHtml} />}
    {
      release.assets.length > 0 && (
        <details>
          <summary>{release.assets.length} release assets</summary>
          <ul>
            {release.assets.map((a) => (
              <li>
                <span class="mode" aria-hidden="true">-rw-r--r--</span>
                <a href={a.url} rel="noopener">
                  {a.name}
                </a>
                <span class="size">{formatSize(a.size)}</span>
              </li>
            ))}
          </ul>
        </details>
      )
    }
  </div>
</article>

<style>
  .entry {
    margin-bottom: 56px;
  }

  .head {
    display: flex;
    align-items: baseline;
    gap: 1.5ch;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--yellow);
    font-weight: 600;
  }

  .tag a {
    color: var(--yellow);
    text-decoration: none;
  }

  .tag a:hover {
    text-decoration: underline;
  }

  .latest {
    color: var(--pink);
  }

  .date {
    margin-left: auto;
    color: var(--faint);
    font-size: 12.5px;
  }

  .name {
    font-weight: 600;
    margin-top: 6px;
  }

  .body {
    border-left: 1px solid var(--rule);
    padding-left: 3ch;
    margin-top: 14px;
  }

  details {
    margin-top: 16px;
  }

  summary {
    cursor: pointer;
    color: var(--dim);
    font-size: 13px;
  }

  summary:hover {
    color: var(--fg);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 10px 0 0;
  }

  li {
    display: flex;
    gap: 2ch;
    align-items: baseline;
    padding: 3px 0;
    font-size: 12.5px;
    overflow-wrap: anywhere;
  }

  .mode {
    color: var(--faint);
    flex-shrink: 0;
  }

  .size {
    margin-left: auto;
    color: var(--faint);
    flex-shrink: 0;
  }

  @media (max-width: 560px) {
    .mode {
      display: none;
    }
  }
</style>

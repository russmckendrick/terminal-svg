---
import type { Release } from "../lib/releases";
import { formatDate, formatSize } from "../lib/releases";

interface Props {
  release: Release;
  latest?: boolean;
}

const { release, latest = false } = Astro.props;
const id = release.tag.toLowerCase().replace(/[^a-z0-9]+/g, "-");
---

<article class:list={["release-entry", { latest }]} id={id}>
  <header>
    <div>
      <span class="version">{release.tag}</span>
      {latest && <span class="latest-badge">Latest release</span>}
      <h2>{release.name}</h2>
    </div>
    <time datetime={release.publishedAt}>{formatDate(release.publishedAt)}</time
    >
  </header>

  <div class="release-body prose" set:html={release.bodyHtml} />

  <div class="release-footer">
    <a class="text-link" href={release.htmlUrl} rel="noopener"
      >View on GitHub <span aria-hidden="true">↗</span></a
    >
    {
      release.assets.length > 0 && (
        <details class="release-downloads">
          <summary>Download files ({release.assets.length})</summary>
          <ul>
            {release.assets.map((asset) => (
              <li>
                <a href={asset.url} rel="noopener">
                  <span>{asset.name}</span>
                  <span>{formatSize(asset.size)} ↗</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      )
    }
  </div>
</article>

<style>
  .release-entry {
    padding: 52px 0 72px;
    border-bottom: 1px solid var(--line-strong);
    scroll-margin-top: calc(var(--nav-h) + 22px);
  }

  .release-entry:first-child {
    padding-top: 0;
  }

  header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 34px;
  }

  .version,
  .latest-badge {
    display: inline-flex;
    min-height: 26px;
    align-items: center;
    padding: 4px 8px;
    color: var(--blue-deep);
    background: var(--blue-wash);
    border-radius: 6px;
    font-size: 11px;
    font-weight: 740;
  }

  .latest-badge {
    margin-left: 6px;
    color: var(--ink);
    background: var(--lime-soft);
  }

  h2 {
    max-width: 760px;
    margin-top: 13px;
    font-size: clamp(34px, 4vw, 48px);
    font-weight: 690;
    letter-spacing: -0.05em;
    line-height: 1.05;
    text-wrap: balance;
  }

  time {
    flex: 0 0 auto;
    padding-top: 5px;
    color: var(--ink-faint);
    font-size: 12px;
  }

  .release-body :global(> h1:first-child) {
    display: none;
  }

  .release-body :global(h2) {
    font-size: 27px;
  }

  .release-body :global(h3) {
    font-size: 20px;
  }

  .release-body :global(.heading-anchor) {
    display: none;
  }

  .release-footer {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }

  .release-downloads {
    margin-top: 22px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 10px;
  }

  .release-downloads summary {
    padding: 14px 16px;
    color: var(--ink);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
  }

  .release-downloads ul {
    list-style: none;
    padding: 0 16px 10px;
  }

  .release-downloads li {
    border-top: 1px solid var(--line);
  }

  .release-downloads a {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 10px 0;
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: 10px;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .release-downloads a span:last-child {
    flex: 0 0 auto;
    color: var(--blue-deep);
  }

  @media (max-width: 620px) {
    .release-entry {
      padding-block: 46px 58px;
    }

    header {
      flex-direction: column;
      gap: 12px;
    }

    .release-downloads a {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>

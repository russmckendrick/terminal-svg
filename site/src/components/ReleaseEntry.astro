---
import type { Release } from '../lib/releases';
import { formatDate, formatSize } from '../lib/releases';

interface Props {
  release: Release;
  latest?: boolean;
}

const { release, latest = false } = Astro.props;
const excerpt = release.bodyHtml.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const shortExcerpt = excerpt.length > 280 ? `${excerpt.slice(0, 280).replace(/\s+\S*$/, '')}…` : excerpt;
---

<article class:list={['entry', { latest }]} data-reveal>
  <header>
    <div class="entry-title">
      <h2>
        <a href={release.htmlUrl} rel="noopener">{release.name}</a>
        {latest && <span class="badge">Latest</span>}
      </h2>
    </div>
    <time datetime={release.publishedAt}>{formatDate(release.publishedAt)}</time>
  </header>

  <div class="entry-body">
    <p class="excerpt">{shortExcerpt}</p>
    <div class="entry-actions">
      <a class="release-link" href={release.htmlUrl} rel="noopener">View full notes on GitHub ↗</a>
      {
        release.assets.length > 0 && (
          <details class="downloads-details">
            <summary>Downloads ({release.assets.length})</summary>
            <ul>
              {release.assets.map((a) => (
                <li>
                  <a href={a.url} rel="noopener">{a.name}</a>
                  <span class="size">{formatSize(a.size)}</span>
                </li>
              ))}
            </ul>
          </details>
        )
      }
    </div>
  </div>
</article>

<style>
  .entry {
    padding: 32px 0 34px;
    border-bottom: 1px solid #d8cec0;
  }

  .entry.latest {
    padding-top: 36px;
  }

  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
  }

  .entry-title {
    display: flex;
    align-items: baseline;
    min-width: 0;
    gap: 16px;
  }

  h2 {
    min-width: 0;
    font-family: var(--mono);
    font-size: clamp(20px, 2.2vw, 28px);
    font-weight: 600;
    letter-spacing: -0.06em;
  }

  h2 a {
    color: var(--text-dark);
  }

  h2 a:hover {
    color: var(--link-on-light);
    text-decoration: none;
  }

  .badge {
    display: inline-block;
    margin-left: 10px;
    padding: 3px 7px;
    color: #1b140e;
    background: var(--blue);
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0;
    vertical-align: 4px;
  }

  time {
    flex: 0 0 auto;
    color: var(--text-dark-2);
    font-family: var(--mono);
    font-size: 12px;
  }

  .entry-body {
    display: grid;
    grid-template-columns: minmax(0, 0.84fr) minmax(240px, 1.16fr);
    gap: 44px;
    margin-top: 20px;
    padding-left: 42px;
  }

  .excerpt {
    max-width: 54ch;
    color: var(--text-dark-2);
    font-size: 16px;
    line-height: 1.58;
  }

  .entry-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .release-link {
    color: var(--home-rust-dark);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
  }

  .release-link:hover {
    color: #7f3d22;
    text-decoration: none;
  }

  details {
    border-top: 1px solid #d8cec0;
    padding-top: 12px;
  }

  summary {
    color: var(--link-on-light);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
  }

  ul {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
  }

  li {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding: 7px 0;
    border-bottom: 1px solid #e5ddd2;
    font-family: var(--mono);
    font-size: 11px;
    overflow-wrap: anywhere;
  }

  li:last-child { border-bottom: none; }

  li a { color: var(--text-dark); }
  li a:hover { color: var(--link-on-light); }

  .size {
    flex-shrink: 0;
    color: var(--text-dark-2);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 700px) {
    header { align-items: flex-start; flex-direction: column; gap: 10px; }
    .entry-body { grid-template-columns: 1fr; gap: 22px; padding-left: 0; }
  }
</style>

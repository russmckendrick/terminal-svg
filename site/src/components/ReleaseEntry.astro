---
// One release as a clean white card: version, date, notes, downloads.
import type { Release } from '../lib/releases';
import { formatDate, formatSize } from '../lib/releases';

interface Props {
  release: Release;
  latest?: boolean;
}

const { release, latest = false } = Astro.props;
---

<article class="entry">
  <header>
    <h3>
      <a href={release.htmlUrl} rel="noopener">{release.name}</a>
      {latest && <span class="badge">Latest</span>}
    </h3>
    <time datetime={release.publishedAt}>{formatDate(release.publishedAt)}</time>
  </header>
  {release.bodyHtml && <div class="prose" set:html={release.bodyHtml} />}
  {
    release.assets.length > 0 && (
      <details>
        <summary>Downloads ({release.assets.length})</summary>
        <ul>
          {release.assets.map((a) => (
            <li>
              <a href={a.url} rel="noopener">
                {a.name}
              </a>
              <span class="size">{formatSize(a.size)}</span>
            </li>
          ))}
        </ul>
      </details>
    )
  }
</article>

<style>
  .entry {
    background: var(--white);
    border-radius: var(--radius);
    padding: 34px 38px;
  }

  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  h3 {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.017em;
  }

  h3 a {
    color: var(--text-dark);
  }

  h3 a:hover {
    color: var(--link-on-light);
    text-decoration: none;
  }

  .badge {
    font-size: 12px;
    font-weight: 500;
    color: #fff;
    background: var(--blue);
    border-radius: 980px;
    padding: 2px 10px;
  }

  time {
    color: var(--text-dark-2);
    font-size: 14px;
  }

  details {
    margin-top: 22px;
    border-top: 1px solid #e8e8ed;
    padding-top: 16px;
  }

  summary {
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    color: var(--link-on-light);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
  }

  li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 14px;
    padding: 7px 0;
    font-size: 13px;
    overflow-wrap: anywhere;
    border-bottom: 1px solid #f0f0f5;
  }

  li:last-child {
    border-bottom: none;
  }

  .size {
    color: var(--text-dark-2);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
</style>

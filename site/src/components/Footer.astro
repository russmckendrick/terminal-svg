---
import { getLatest, REPO_URL } from "../lib/releases";

const latest = await getLatest();
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-brand">
      <div>
        <strong>terminal-svg</strong>
        <p>Terminal output, drawn for the web.</p>
      </div>
    </div>

    <div class="footer-links" aria-label="Footer navigation">
      <div>
        <span>Explore</span><a href="/gallery/">Examples</a><a href="/docs/"
          >Documentation</a
        ><a href="/releases/">Releases</a>
      </div>
      <div>
        <span>Project</span><a href={REPO_URL} rel="noopener">Source</a><a
          href={`${REPO_URL}/issues`}
          rel="noopener">Issues</a
        ><a href="/docs/architecture/">Architecture</a>
      </div>
    </div>
  </div>
  <div class="shell footer-bottom">
    <span
      >Built in Rust by <a
        href="https://github.com/russmckendrick"
        rel="noopener">Russ McKendrick</a
      >.</span
    >
    <span>MIT · Fonts under SIL OFL {latest && `· ${latest.tag}`}</span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 76px 0 28px;
    color: #d9dee7;
    background: var(--ink);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 80px;
    padding-bottom: 70px;
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: 15px;
  }

  .footer-brand strong {
    color: white;
    font-size: 22px;
    letter-spacing: -0.035em;
  }

  .footer-brand p {
    margin-top: 4px;
    color: #9ba4b2;
    font-size: 15px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(120px, 1fr));
    gap: 70px;
  }

  .footer-links > div {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .footer-links span {
    margin-bottom: 5px;
    color: #7f8998;
    font-size: 12px;
    font-weight: 700;
  }

  .footer-links a,
  .footer-bottom a {
    color: #d9dee7;
    text-decoration: none;
  }

  .footer-links a:hover,
  .footer-bottom a:hover {
    color: white;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding-top: 22px;
    color: #87919f;
    border-top: 1px solid #303540;
    font-size: 13px;
  }

  @media (max-width: 720px) {
    .site-footer {
      padding-top: 56px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 46px;
      padding-bottom: 52px;
    }

    .footer-links {
      gap: 40px;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>

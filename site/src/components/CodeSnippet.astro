---
interface Props {
  code: string;
  label?: string;
}

const { code, label = "Shell" } = Astro.props;
---

<div class="snippet">
  <div class="head">
    <span class="label">{label}</span>
    <button
      class="copy"
      type="button"
      aria-label={`Copy ${label}`}
      aria-live="polite"
      data-copy={code}>Copy</button
    >
  </div>
  <pre><code>{code}</code></pre>
</div>

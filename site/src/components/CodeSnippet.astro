---
// A miniature macOS Terminal window: traffic lights, centred title,
// Copy control, one command.
interface Props {
  code: string;
  label?: string;
}

const { code, label = 'Terminal' } = Astro.props;
---

<div class="snippet">
  <div class="head">
    <span class="lights" aria-hidden="true"><i class="r"></i><i class="y"></i><i class="g"></i></span>
    <span class="label">{label}</span>
    <button class="copy" data-copy={code}>Copy</button>
  </div>
  <pre><code>{code}</code></pre>
</div>

<style>
  .snippet {
    background: #1d1d1f;
    border-radius: 12px;
    overflow: hidden;
    text-align: left;
    box-shadow:
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.14),
      0 12px 32px rgba(0, 0, 0, 0.22);
  }

  .head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 14px;
    background: linear-gradient(180deg, #333336, #2a2a2d);
    border-bottom: 1px solid rgba(0, 0, 0, 0.45);
  }

  .lights {
    display: inline-flex;
    gap: 7px;
    justify-self: start;
  }

  .lights i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.2);
  }

  .r { background: #ff5f57; }
  .y { background: #febc2e; }
  .g { background: #28c840; }

  .label {
    justify-self: center;
    color: #9a9a9e;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    padding: 0 10px;
  }

  .copy {
    justify-self: end;
    background: none;
    border: none;
    color: #2997ff;
    font-family: var(--sans);
    font-size: 12px;
    cursor: pointer;
    padding: 0;
  }

  .copy:hover {
    text-decoration: underline;
  }

  .copy:global(.copied) {
    color: #30d158;
  }

  pre {
    margin: 0;
    padding: 16px 18px;
    overflow-x: auto;
  }

  code {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
    color: #f5f5f7;
    white-space: pre;
  }
</style>

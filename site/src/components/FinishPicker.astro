---
// "Available in seven finishes." — Apple colour-picker treatment for themes.
// The same fixture rendered in every theme; swatches swap the image with a
// crossfade. All seven SVGs are in the DOM (they're ~10 KB each); JS only
// toggles a class, so with JS off the default theme still shows.
import ThemeChip from './ThemeChip.astro';
import { find, THEME_META } from '../lib/gallery';

const fixture = 'starship';
const shots = THEME_META.map((f) => ({ ...f, name: f.label, item: find(f.key, fixture) })).filter(
  (f) => f.item !== undefined
);
---

<div class="picker" data-picker>
  <div class="stage">
    {
      shots.map((s, i) => (
        <img
          class:list={['shot', { on: i === 0 }]}
          data-finish={s.key}
          src={s.item!.url}
          alt={`The ${fixture} prompt rendered in the ${s.name} theme`}
          width={s.item!.width}
          height={s.item!.height}
          loading="lazy"
          decoding="async"
        />
      ))
    }
  </div>
  <div class="swatches" role="group" aria-label="Choose a theme">
    {
      shots.map((s, i) => (
        <button
          class:list={['swatch', { on: i === 0 }]}
          data-finish={s.key}
          aria-label={s.name}
          aria-pressed={i === 0 ? 'true' : 'false'}
          title={s.name}
        >
          <ThemeChip theme={s} />
        </button>
      ))
    }
  </div>
  <p class="name" data-finish-name>{shots[0]?.name}</p>
</div>

<script>
  for (const picker of document.querySelectorAll<HTMLElement>('[data-picker]')) {
    const shots = picker.querySelectorAll<HTMLElement>('.shot');
    const swatches = picker.querySelectorAll<HTMLElement>('.swatch');
    const label = picker.querySelector<HTMLElement>('[data-finish-name]');
    picker.addEventListener('click', (e) => {
      const swatch = (e.target as HTMLElement).closest<HTMLElement>('.swatch');
      if (!swatch) return;
      const key = swatch.dataset.finish;
      for (const s of shots) s.classList.toggle('on', s.dataset.finish === key);
      for (const s of swatches) {
        const selected = s === swatch;
        s.classList.toggle('on', selected);
        s.setAttribute('aria-pressed', String(selected));
      }
      if (label) label.textContent = swatch.getAttribute('aria-label');
    });
  }
</script>

<style>
  .picker {
    text-align: center;
  }

  .stage {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    aspect-ratio: 668 / 175;
  }

  .shot {
    position: absolute;
    inset: 0;
    width: 100%;
    height: auto;
    opacity: 0;
    transition: opacity 0.45s ease;
    filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.18));
  }

  .shot.on {
    opacity: 1;
  }

  .swatches {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-top: 56px;
  }

  .swatch {
    border: none;
    background: none;
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    line-height: 0;
    transition: transform 0.2s ease;
  }

  .swatch :global(svg) {
    display: block;
  }

  .swatch:hover {
    transform: scale(1.1) translateY(-1px);
  }

  .swatch.on {
    outline: 2px solid var(--blue);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .shot {
      transition: none;
    }
  }

  .name {
    margin-top: 18px;
    font-size: 15px;
    color: var(--text-dark-2);
  }

  @media (max-width: 560px) {
    .swatches {
      gap: 10px;
      flex-wrap: wrap;
    }

    .swatch :global(svg) {
      width: 36px;
      height: auto;
    }
  }
</style>

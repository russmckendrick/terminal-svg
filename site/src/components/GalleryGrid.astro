---
import type { GalleryItem } from "../lib/gallery";
import { themeLabel, fixtureLabel } from "../lib/gallery";

interface Props {
  items: GalleryItem[];
  lightbox?: boolean;
  compact?: boolean;
}

const { items, lightbox = false, compact = false } = Astro.props;
---

<div class:list={["specimen-grid", { compact }]}>
  {
    items.map((item) => (
      <figure
        class="specimen"
        data-theme={item.theme}
        data-fixture={item.fixture}
      >
        <div class="specimen-meta">
          <>
            <span>
              {item.width} × {item.height}
            </span>
            <span>{item.animated ? "Animated SVG" : "SVG"}</span>
          </>
        </div>
        {lightbox ? (
          <button
            type="button"
            class="artboard"
            data-lightbox
            data-url={item.url}
            data-caption={`${fixtureLabel(item.fixture)} — ${themeLabel(item.theme)}`}
            data-fixture-label={fixtureLabel(item.fixture)}
            data-theme-label={themeLabel(item.theme)}
            data-dimensions={`${item.width} × ${item.height}`}
            aria-label={`Inspect ${fixtureLabel(item.fixture)} in ${themeLabel(item.theme)}`}
          >
            <i />
            <i />
            <i />
            <i />
            <img
              src={item.url}
              alt={`${fixtureLabel(item.fixture)} rendered in the ${themeLabel(item.theme)} theme`}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
          </button>
        ) : (
          <div class="artboard">
            <img
              src={item.url}
              alt={`${fixtureLabel(item.fixture)} rendered in the ${themeLabel(item.theme)} theme`}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
        <figcaption>
          <span>
            <>
              <strong>{fixtureLabel(item.fixture)}</strong>
              <span>{themeLabel(item.theme)}</span>
            </>
          </span>
          <span class="inspect">Inspect ↗</span>
        </figcaption>
      </figure>
    ))
  }
</div>

<style>
  .specimen-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 48px 28px;
  }

  .specimen {
    min-width: 0;
    margin: 0;
    overflow: visible;
  }

  .specimen-meta {
    display: flex;
    justify-content: space-between;
    gap: 15px;
    padding: 0 3px 10px;
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 650;
  }

  .artboard {
    position: relative;
    display: grid;
    width: 100%;
    aspect-ratio: 1.52 / 1;
    padding: 26px;
    place-items: center;
    overflow: visible;
    background-color: var(--surface);
    background-image:
      linear-gradient(#eef1ed 1px, transparent 1px),
      linear-gradient(90deg, #eef1ed 1px, transparent 1px);
    background-size: 20px 20px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  button.artboard {
    color: inherit;
    cursor: zoom-in;
  }

  .artboard:hover {
    border-color: var(--blue);
    box-shadow: 0 18px 44px rgba(36, 48, 74, 0.11);
    transform: translateY(-2px);
  }

  .artboard > i {
    position: absolute;
    z-index: 2;
    display: none;
    width: 10px;
    height: 10px;
    background: white;
    border: 2px solid var(--blue);
  }

  .artboard:hover > i,
  .artboard:focus-visible > i {
    display: block;
  }

  .artboard > i:nth-child(1) {
    top: -6px;
    left: -6px;
  }
  .artboard > i:nth-child(2) {
    top: -6px;
    right: -6px;
  }
  .artboard > i:nth-child(3) {
    bottom: -6px;
    left: -6px;
  }
  .artboard > i:nth-child(4) {
    right: -6px;
    bottom: -6px;
  }

  .artboard img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 18px 30px rgba(30, 38, 52, 0.14));
  }

  figcaption {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 3px 0;
  }

  figcaption > span:first-child strong,
  figcaption > span:first-child > span {
    display: block;
  }

  figcaption strong {
    color: var(--ink);
    font-size: 15px;
    letter-spacing: -0.02em;
  }

  figcaption > span:first-child > span {
    margin-top: 2px;
    color: var(--ink-soft);
    font-size: 12px;
  }

  .inspect {
    color: var(--blue-deep);
    font-size: 12px;
    font-weight: 700;
  }

  .compact {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 36px 20px;
  }

  .compact .artboard {
    padding: 16px;
  }

  @media (max-width: 900px) {
    .compact {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .specimen-grid,
    .compact {
      grid-template-columns: 1fr;
      gap: 38px;
    }

    .artboard {
      padding: 16px;
    }
  }
</style>

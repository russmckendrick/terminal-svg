---
// Apple-style product tiles: white rounded cards on gray, generous padding.
import type { GalleryItem } from '../lib/gallery';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="grid">
  {
    items.map((item) => (
      <figure data-theme={item.theme} data-fixture={item.fixture}>
        <img
          src={item.url}
          alt={`${item.fixture} rendered in the ${item.theme} theme`}
          width={item.width}
          height={item.height}
          loading="lazy"
          decoding="async"
        />
        <figcaption>
          <span class="fixture">{item.fixture}</span>
          <span class="theme">{item.theme}</span>
          {item.animated && <span class="anim">Animated</span>}
        </figcaption>
      </figure>
    ))
  }
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: 20px;
  }

  figure[hidden] {
    display: none;
  }

  figure {
    margin: 0;
    background: var(--white);
    border-radius: var(--radius);
    padding: 26px 26px 20px;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.3s ease;
  }

  figure:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    margin-bottom: 16px;
  }

  figcaption {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: auto;
    font-size: 13px;
  }

  .fixture {
    font-weight: 600;
    color: var(--text-dark);
  }

  .theme {
    color: var(--text-dark-2);
  }

  .anim {
    margin-left: auto;
    color: var(--link-on-light);
    font-size: 12px;
  }
</style>

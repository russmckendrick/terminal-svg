---
// A two-column render catalog. The SVGs stay close to their natural proportions,
// with the fixture and theme treated as useful metadata rather than decoration.
import type { GalleryItem } from '../lib/gallery';
import { themeLabel, fixtureLabel } from '../lib/gallery';

interface Props {
  items: GalleryItem[];
  lightbox?: boolean;
}

const { items, lightbox = false } = Astro.props;
---

<div class="grid">
  {
    items.map((item) => (
      <figure class="tile" data-theme={item.theme} data-fixture={item.fixture}>
        {lightbox ? (
          <button
            class="media"
            data-lightbox
            data-url={item.url}
            data-caption={`${fixtureLabel(item.fixture)} — ${themeLabel(item.theme)}`}
            aria-label={`View ${fixtureLabel(item.fixture)} in ${themeLabel(item.theme)} full size`}
          >
            <img
              src={item.url}
              alt={`${fixtureLabel(item.fixture)} rendered in the ${themeLabel(item.theme)} theme`}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
          </button>
        ) : (
          <div class="media">
            <img
              src={item.url}
              alt={`${fixtureLabel(item.fixture)} rendered in the ${themeLabel(item.theme)} theme`}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
        <figcaption>
          <span class="fixture">{fixtureLabel(item.fixture)}</span>
          <span class="theme">{themeLabel(item.theme)}</span>
          {item.animated && (
            <span class="anim">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M8 5.5v13a1 1 0 0 0 1.5.87l11-6.5a1 1 0 0 0 0-1.74l-11-6.5A1 1 0 0 0 8 5.5z" />
              </svg>
              Animated
            </span>
          )}
        </figcaption>
      </figure>
    ))
  }
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 56px 28px;
  }

  .tile[hidden] {
    display: none;
  }

  .tile {
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid #d8cec0;
  }

  /* every slot shares one ratio, so rows align no matter which SVG is inside */
  .media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1.52 / 1;
    padding: 20px;
    background: #ebe5da;
    border: 1px solid #d7ccbd;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  button.media {
    cursor: zoom-in;
  }

  .media img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 18px 36px rgba(32, 24, 16, 0.16));
    transition: transform 0.35s cubic-bezier(0.25, 0.1, 0.25, 1), filter 0.35s ease;
  }

  .tile:hover .media {
    background: #f0e9de;
    border-color: var(--blue);
  }

  .tile:hover .media img {
    transform: translateY(-4px) scale(1.015);
    filter: drop-shadow(0 28px 52px rgba(32, 24, 16, 0.22));
  }

  figcaption {
    display: flex;
    justify-content: flex-start;
    align-items: baseline;
    gap: 10px;
    padding: 14px 2px 0;
    font-family: var(--mono);
    font-size: 12px;
  }

  .fixture {
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-dark);
  }

  .theme {
    color: var(--text-dark-2);
    font-size: 11px;
  }

  .anim {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--link-on-light);
    font-size: 12px;
    font-weight: 500;
  }

  .anim svg {
    width: 10px;
    height: 10px;
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .media {
      padding: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .media,
    .media img {
      transition: none;
    }
  }
</style>

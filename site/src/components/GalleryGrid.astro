---
// The shots ARE the layout: a wide two-column masonry, every SVG rendered
// near its natural size, floating directly on the background with its own
// window chrome. Minimal caption below; click opens the lightbox.
import type { GalleryItem } from '../lib/gallery';
import { themeLabel, fixtureLabel } from '../lib/gallery';

interface Props {
  items: GalleryItem[];
  lightbox?: boolean;
}

const { items, lightbox = false } = Astro.props;
---

<div class="masonry">
  {
    items.map((item) => (
      <figure class="tile" data-theme={item.theme} data-fixture={item.fixture}>
        {lightbox ? (
          <button
            class="media"
            data-lightbox
            data-url={item.url}
            data-caption={`${fixtureLabel(item.fixture)} — ${themeLabel(item.theme)}`}
            aria-label={`View ${fixtureLabel(item.fixture)} in ${themeLabel(item.theme)} full size`}
          >
            <img
              src={item.url}
              alt={`${fixtureLabel(item.fixture)} rendered in the ${themeLabel(item.theme)} theme`}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
          </button>
        ) : (
          <div class="media">
            <img
              src={item.url}
              alt={`${fixtureLabel(item.fixture)} rendered in the ${themeLabel(item.theme)} theme`}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
        <figcaption>
          <span class="fixture">{fixtureLabel(item.fixture)}</span>
          <span class="theme">{themeLabel(item.theme)}</span>
          {item.animated && (
            <span class="anim">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M8 5.5v13a1 1 0 0 0 1.5.87l11-6.5a1 1 0 0 0 0-1.74l-11-6.5A1 1 0 0 0 8 5.5z" />
              </svg>
              Animated
            </span>
          )}
        </figcaption>
      </figure>
    ))
  }
</div>

<style>
  .masonry {
    columns: 2 460px;
    column-gap: 48px;
  }

  .tile[hidden] {
    display: none;
  }

  .tile {
    margin: 0 0 56px;
    break-inside: avoid;
  }

  .media {
    display: block;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
  }

  button.media {
    cursor: zoom-in;
  }

  .media img {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.16));
    transition: transform 0.35s cubic-bezier(0.25, 0.1, 0.25, 1), filter 0.35s ease;
  }

  .tile:hover .media img {
    transform: translateY(-4px) scale(1.012);
    filter: drop-shadow(0 28px 52px rgba(0, 0, 0, 0.22));
  }

  figcaption {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 14px 6px 0;
    font-size: 14px;
  }

  .fixture {
    font-weight: 600;
    letter-spacing: -0.016em;
    color: var(--text-dark);
  }

  .theme {
    color: var(--text-dark-2);
    font-size: 13px;
  }

  .anim {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--link-on-light);
    font-size: 12px;
    font-weight: 500;
  }

  .anim svg {
    width: 10px;
    height: 10px;
  }

  @media (max-width: 640px) {
    .tile {
      margin-bottom: 44px;
    }
  }
</style>
